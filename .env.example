# Copia este archivo a .env y ajusta los valores.

# --- Base de datos (PostgreSQL) ---
# Local con Docker (ver docker-compose.yml):  docker compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mundial?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mundial?schema=public"

# En Vercel Postgres (Neon) usa los valores que te da la integración:
#   DATABASE_URL = POSTGRES_PRISMA_URL        (pooled, con ?pgbouncer=true)
#   DIRECT_URL   = POSTGRES_URL_NON_POOLING   (conexión directa)

# --- Sesiones ---
# Secreto para firmar los JWT de sesión. Genera uno largo y aleatorio en prod,
# p.ej.:  openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-en-produccion"
